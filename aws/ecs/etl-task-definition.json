{
  "family": "financial-data-etl",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "1024",
  "memory": "4096",
  "executionRoleArn": "arn:aws:iam::295933007543:role/ecsTaskExecutionRole",
  "taskRoleArn": "arn:aws:iam::295933007543:role/financial-etl-task-role",
  "containerDefinitions": [
    {
      "name": "etl",
      "image": "295933007543.dkr.ecr.us-east-2.amazonaws.com/financial-data-etl:latest",
      "essential": true,
      "entryPoint": ["python", "-m", "financial_data_etl.main_runner"],
      "environment": [
        {"name": "WS_POOL_SIZE", "value": "2"},
        {"name": "SYMBOLS_PER_BATCH", "value": "5"},
        {"name": "VPS_S3_BUCKET", "value": "leonardovila-financial-raw"},
        {"name": "VPS_S3_PREFIX", "value": "raw/tv"},
        {"name": "AWS_REGION", "value": "us-east-2"}
      ],
      "secrets": [
        {"name": "DATABASE_URL", "valueFrom": "arn:aws:secretsmanager:us-east-2:295933007543:secret:financial-data/rds-vqG2ip"},
        {"name": "INTERNAL_API_TOKEN", "valueFrom": "arn:aws:secretsmanager:us-east-2:295933007543:secret:financial-data/internal-api-token-4QMQ9b"}
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/financial-data-etl",
          "awslogs-region": "us-east-2",
          "awslogs-stream-prefix": "etl"
        }
      }
    }
  ]
}
