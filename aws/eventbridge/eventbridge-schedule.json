  "ScheduleExpression": "cron(0 21 ? * MON-FRI *)",
  "ScheduleExpressionTimezone": "UTC",
  "FlexibleTimeWindow": {
    "Mode": "OFF"
  },
  "Target": {
    "Arn": "arn:aws:lambda:us-east-2:295933007543:function:etl-trigger",
    "RoleArn": "arn:aws:iam::295933007543:role/EventBridgeSchedulerRole",
    "Input": "{}"
  },
  "State": "ENABLED"
}
